rules_version = '2';

// Casarico Board Hub — Firestore security rules.
// Paste these into  Firebase console → Firestore Database → Rules → Publish.
//
// They enforce the roles server-side, so a viewer cannot write even if they
// edit the page in their browser:
//   • read  — any signed-in Google user (they still need to sign in to see the board)
//   • write — only the editor email(s) listed below
//
// Keep the editor list here in sync with window.EDITOR_EMAILS in index.html.

service cloud.firestore {
  match /databases/{database}/documents {

    match /boards/{boardId} {
      allow read: if request.auth != null;

      allow write: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
             'daniel@immo-ressource.ch'
             // , 'another-editor@immo-ressource.ch'
           ];
    }
  }
}
